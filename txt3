    <style>
        :root {
            --primary-teal: #0D9488;
            --dark-teal: #115E59;
            --light-teal: #99F6E4;
            --accent-navy: #0F172A;
            --surface-bg: #F8FAFC;
            --text-main: #334155;
            --text-light: #64748B;
            --white: #FFFFFF;
            --gradient-teal: linear-gradient(135deg, #0D9488 0%, #0F766E 100%);
        }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-main);
            background-color: var(--white);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .serif-font {
            font-family: 'Playfair Display', serif;
        }

        /* --- Utilities --- */
        .text-gradient {
            background: var(--gradient-teal);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .bg-surface { background-color: var(--surface-bg); }
        
        .section-padding { padding: 100px 0; }
        
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 16px;
            box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
        }

        /* --- Buttons --- */
        .btn-primary-action {
            background: var(--primary-teal);
            color: var(--white);
            padding: 14px 32px;
            border-radius: 8px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .btn-primary-action:hover {
            background: var(--dark-teal);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(13, 148, 136, 0.3);
        }

        .btn-outline-action {
            background: transparent;
            color: var(--primary-teal);
            padding: 14px 32px;
            border-radius: 8px;
            font-weight: 600;
            border: 2px solid var(--primary-teal);
            transition: all 0.3s ease;
        }

        .btn-outline-action:hover {
            background: var(--primary-teal);
            color: var(--white);
        }

        /* --- Navigation --- */
        .navbar {
            padding: 20px 0;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .navbar-brand {
            font-family: 'Plus Jakarta Sans';
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--accent-navy);
            letter-spacing: -0.03em;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-main);
            margin: 0 12px;
            font-size: 0.95rem;
        }

        .nav-link.active { color: var(--primary-teal); }

        /* --- Section 1: Hero --- */
        .hero-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero-blob {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(153, 246, 228, 0.4) 0%, rgba(255,255,255,0) 70%);
            border-radius: 50%;
            z-index: -1;
            top: -100px;
            right: -100px;
        }

        /* --- Section 2: Challenges (Problem Cards) --- */
        .challenge-card {
            background: var(--white);
            border: 1px solid #E2E8F0;
            border-radius: 12px;
            padding: 2rem;
            margin-bottom: 1rem;
            transition: transform 0.3s ease;
        }
        
        .challenge-card:hover {
            border-color: #F87171; /* Subtle Red on hover indicating pain */
            transform: translateX(10px);
        }
        
        .challenge-icon {
            color: #EF4444;
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        /* --- Section 3: Consulting Services --- */
        .service-card-consulting {
            background: var(--surface-bg);
            border-left: 4px solid var(--primary-teal);
            padding: 2rem;
            height: 100%;
            border-radius: 0 12px 12px 0;
            transition: all 0.3s ease;
        }

        .service-card-consulting:hover {
            background: var(--white);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transform: translateY(-5px);
        }

        /* --- Section 4: Timeline --- */
        .timeline-wrapper {
            position: relative;
            padding: 40px 0;
        }
        
        .timeline-line {
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #E2E8F0;
            transform: translateX(-50%);
        }
        
        .timeline-progress {
            position: absolute;
            left: 50%;
            top: 0;
            width: 2px;
            background: var(--primary-teal);
            transform: translateX(-50%);
            height: 0%; /* GSAP controls this */
        }

        .timeline-item {
            position: relative;
            margin-bottom: 60px;
            opacity: 0.3; /* Dimmed initially */
            transition: opacity 0.5s;
        }
        
        .timeline-item.active { opacity: 1; }

        .timeline-dot {
            width: 20px;
            height: 20px;
            background: var(--white);
            border: 4px solid var(--text-light);
            border-radius: 50%;
            position: absolute;
            left: 50%;
            top: 0;
            transform: translateX(-50%);
            z-index: 2;
        }

        .timeline-item.active .timeline-dot {
            border-color: var(--primary-teal);
            background: var(--primary-teal);
            box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.2);
        }

        /* --- Section 5: Platform Pinned --- */
        .dashboard-visual {
            position: sticky;
            top: 10vh;
            height: 80vh;
            background: var(--accent-navy);
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .feature-badge {
            position: absolute;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            padding: 12px 20px;
            border-radius: 50px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.9rem;
            opacity: 0; /* Animated in */
            transform: scale(0.8);
        }
        
        .feature-badge i { color: var(--primary-teal); }

        /* --- Section 6: Split Layout Merge --- */
        .split-section-container {
            display: flex;
            height: 100vh;
            overflow: hidden;
            position: relative;
        }
        
        .split-panel {
            flex: 1;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem;
            transition: all 0.5s ease;
        }
        
        .split-left { background: #F1F5F9; border-right: 1px solid #E2E8F0; }
        .split-right { background: var(--white); }

        .merge-icon-center {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            font-size: 4rem;
            color: var(--primary-teal);
            z-index: 10;
            opacity: 0;
        }

        /* --- Section 8: Metrics --- */
        .metric-card {
            text-align: center;
            padding: 3rem 1rem;
        }
        
        .metric-number {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--primary-teal);
            line-height: 1;
        }

        /* --- Section 10: Team --- */
        .team-card {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
        }
        
        .team-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        
        .team-card:hover .team-img { transform: scale(1.05); }
        
        .team-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 20px;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            color: white;
            transform: translateY(100%);
            transition: transform 0.3s ease;
        }
        
        .team-card:hover .team-overlay { transform: translateY(0); }

        /* --- Section 11: Testimonials --- */
        .marquee-container {
            overflow: hidden;
            white-space: nowrap;
            position: relative;
        }
        
        .marquee-content {
            display: inline-block;
            animation: scroll-text 40s linear infinite;
        }
        
        .testimonial-bubble {
            display: inline-block;
            background: var(--surface-bg);
            padding: 2rem;
            border-radius: 16px;
            margin: 0 20px;
            width: 400px;
            vertical-align: top;
            white-space: normal;
        }

        @keyframes scroll-text {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* --- Footer --- */
        .footer {
            background: var(--accent-navy);
            color: #94A3B8;
            padding: 80px 0 30px;
        }
        
        .footer h5 { color: var(--white); margin-bottom: 1.5rem; }
        
        .footer-link {
            display: block;
            color: #94A3B8;
            text-decoration: none;
            margin-bottom: 10px;
            transition: color 0.3s;
        }
        
        .footer-link:hover { color: var(--light-teal); }

        /* --- Responsive --- */
        @media (max-width: 991px) {
            .split-section-container { flex-direction: column; height: auto; }
            .split-panel { padding: 3rem 1rem; height: auto; }
            .timeline-line { left: 20px; }
            .timeline-progress { left: 20px; }
            .timeline-dot { left: 20px; }
            .timeline-content { margin-left: 50px !important; text-align: left !important; }
        }
    </style>
</head>
