    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js"></script>

    <script>
        // Lenis Smooth Scroll
        const lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            direction: 'vertical',
            gestureDirection: 'vertical',
            smooth: true,
            mouseMultiplier: 1,
            smoothTouch: false,
            touchMultiplier: 2,
        });

        function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Register GSAP Plugins
        gsap.registerPlugin(ScrollTrigger);

        // --- Section 1: Hero Animation ---
        const heroTl = gsap.timeline();
        heroTl.from(".hero-text-content > *", {
            y: 50,
            opacity: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out"
        })
        .from(".hero-img", {
            scale: 0.9,
            opacity: 0,
            duration: 1.2,
            ease: "power2.out"
        }, "-=0.8")
        .from(".hero-card-anim", {
            y: 50,
            opacity: 0,
            duration: 0.8
        }, "-=0.5");

        // --- Section 2: Challenges Reveal ---
        gsap.utils.toArray('.gs-reveal').forEach((elem, i) => {
            gsap.from(elem, {
                scrollTrigger: {
                    trigger: elem,
                    start: "top 90%"
                },
                y: 30,
                opacity: 0,
                duration: 0.6,
                delay: i * 0.1
            });
        });

        // --- Section 3: Consulting Cards ---
        gsap.from(".service-card-consulting", {
            scrollTrigger: {
                trigger: "#consulting",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1
        });

        // --- Section 4: Timeline Animation ---
        const timelineItems = document.querySelectorAll('.timeline-item');
        
        timelineItems.forEach((item, index) => {
            ScrollTrigger.create({
                trigger: item,
                start: "top 80%",
                onEnter: () => {
                    item.classList.add('active');
                    // Update progress bar height
                    const progress = ((index + 1) / timelineItems.length) * 100;
                    gsap.to('.timeline-progress', { height: `${progress}%`, duration: 0.5 });
                }
            });
        });

        // --- Section 5: Platform Pinned Dashboard ---
        // Pin the dashboard visual
        ScrollTrigger.create({
            trigger: ".dashboard-visual",
            start: "top 15%",
            endTrigger: "#platform",
            end: "bottom bottom",
            pin: true,
            pinSpacing: false
        });

        // Animate feature badges as user scrolls through the text list
        document.querySelectorAll('.feature-trigger').forEach((trigger) => {
            const targetId = trigger.getAttribute('data-target');
            const targetEl = document.getElementById(targetId);
            
            ScrollTrigger.create({
                trigger: trigger,
                start: "top 60%",
                end: "bottom 60%",
                onEnter: () => {
                    gsap.to(targetEl, { opacity: 1, scale: 1, duration: 0.5 });
                },
                onLeave: () => {
                    gsap.to(targetEl, { opacity: 0, scale: 0.8, duration: 0.3 });
                },
                onEnterBack: () => {
                    gsap.to(targetEl, { opacity: 1, scale: 1, duration: 0.5 });
                },
                onLeaveBack: () => {
                    gsap.to(targetEl, { opacity: 0, scale: 0.8, duration: 0.3 });
                }
            });
        });

        // --- Section 6: Split Layout Merge ---
        const mergeTl = gsap.timeline({
            scrollTrigger: {
                trigger: "#merge",
                start: "top top",
                end: "bottom bottom",
                scrub: 1
            }
        });

        mergeTl.to(".split-left", { width: "0%", opacity: 0, padding: 0 }, "merge")
               .to(".split-right", { width: "100%", duration: 1 }, "merge")
               .to(".merge-icon-center", { opacity: 1, scale: 1.2, duration: 0.5 }, "merge+=0.5")
               .to(".merge-result-text", { opacity: 1, y: -50, duration: 1 }, "merge+=0.5");

        // --- Section 8: Metrics Counter ---
        gsap.utils.toArray('.counter').forEach(counter => {
            const target = counter.getAttribute('data-target');
            gsap.to(counter, {
                innerText: target,
                duration: 2,
                snap: { innerText: 1 },
                scrollTrigger: {
                    trigger: counter,
                    start: "top 85%",
                    once: true
                }
            });
        });

        // --- Section 10: Team Hover ---
        // Handled via CSS mostly, but let's add a subtle GSAP entrance
        gsap.from(".team-wrapper", {
            scrollTrigger: {
                trigger: "#about",
                start: "top 80%"
            },
            y: 50,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1
        });

        // --- Section 7: Industry Cards Tilt ---
        document.querySelectorAll('.industry-card-trigger').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((y - centerY) / centerY) * -10;
                const rotateY = ((x - centerX) / centerX) * 10;

                gsap.to(card.querySelector('.hover-lift'), {
                    rotationX: rotateX,
                    rotationY: rotateY,
                    transformPerspective: 1000,
                    duration: 0.1
                });
            });
            
            card.addEventListener('mouseleave', () => {
                gsap.to(card.querySelector('.hover-lift'), { rotationX: 0, rotationY: 0, duration: 0.5 });
            });
        });

    </script>
