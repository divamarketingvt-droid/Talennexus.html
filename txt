<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexHR | Premium HR Consulting & SaaS</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-teal: #0F766E;
            --dark-teal: #115E59;
            --light-teal: #5EEAD4;
            --white: #FFFFFF;
            --bg-light: #F8FAFC;
            --text-dark: #0F172A;
            --text-muted: #64748B;
            --glass-border: rgba(255, 255, 255, 0.2);
            --glass-bg: rgba(255, 255, 255, 0.7);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            overflow-x: hidden;
            margin: 0;
            padding: 0;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .display-font {
            font-family: 'Space Grotesk', sans-serif;
        }

        /* --- UI Components --- */
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary-teal), var(--dark-teal));
            color: var(--white);
            border: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(15, 118, 110, 0.3);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .btn-primary-custom::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 0%; height: 100%;
            background: var(--light-teal);
            z-index: -1;
            transition: width 0.3s ease;
        }

        .btn-primary-custom:hover::before {
            width: 100%;
        }

        .btn-primary-custom:hover {
            box-shadow: 0 8px 25px rgba(15, 118, 110, 0.4);
            transform: translateY(-2px);
            color: var(--dark-teal);
        }

        .btn-outline-custom {
            background: transparent;
            color: var(--primary-teal);
            border: 2px solid var(--primary-teal);
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-outline-custom:hover {
            background: var(--primary-teal);
            color: var(--white);
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(31, 38, 135, 0.05);
        }

        .section-padding {
            padding: 120px 0;
        }

        /* --- Navigation --- */
        .navbar {
            padding: 20px 0;
            transition: all 0.4s ease;
            background: rgba(248, 250, 252, 0.8);
            backdrop-filter: blur(10px);
        }
        
        .navbar-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            font-size: 1.8rem;
            color: var(--primary-teal);
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-dark);
            margin: 0 10px;
            position: relative;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0; left: 50%; width: 0; height: 2px;
            background: var(--primary-teal);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-link:hover::after {
            width: 80%;
        }

        /* --- Hero Section --- */
        #hero {
            height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
        }

        .hero-bg-shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.6;
            z-index: -1;
            animation: float 10s infinite ease-in-out;
        }

        .shape-1 { top: -10%; right: -10%; width: 600px; height: 600px; background: #CCFBF1; }
        .shape-2 { bottom: -10%; left: -10%; width: 500px; height: 500px; background: #E0F2FE; }

        .scroll-indicator {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            flex-direction: column;
            align-items: center;
            opacity: 0.7;
        }

        .mouse {
            width: 26px;
            height: 42px;
            border: 2px solid var(--text-dark);
            border-radius: 20px;
            position: relative;
        }

        .wheel {
            width: 4px;
            height: 8px;
            background: var(--text-dark);
            border-radius: 2px;
            position: absolute;
            top: 6px;
            left: 50%;
            transform: translateX(-50%);
            animation: scrollWheel 2s infinite;
        }

        /* --- Horizontal Scroll Section --- */
        #services-wrapper {
            width: 100%;
            height: 100vh;
            overflow: hidden;
            /* Hide scrollbar but keep functionality */
        }

        #services-container {
            display: flex;
            flex-wrap: nowrap;
            height: 100%;
            width: fit-content;
        }

        .service-panel {
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            padding: 0 5%;
            box-sizing: border-box;
        }

        /* --- About Section --- */
        .progress-custom {
            height: 10px;
            background-color: #E2E8F0;
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-bar-custom {
            background: linear-gradient(90deg, var(--primary-teal), var(--light-teal));
            height: 100%;
            width: 0%; /* Animated via JS */
        }

        /* --- SaaS Showcase --- */
        .dashboard-mockup {
            background: url('https://picsum.photos/seed/dashboardui/1200/800.jpg') no-repeat center center;
            background-size: cover;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            border: 1px solid rgba(255,255,255,0.2);
            position: relative;
            z-index: 2;
        }

        .feature-floating-card {
            position: absolute;
            background: rgba(255, 255, 255, 0.95);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 15px;
            z-index: 3;
            opacity: 0; /* JS handles reveal */
            transform: translateY(20px);
            max-width: 300px;
        }

        /* --- Industries Tilt --- */
        .industry-card {
            transition: transform 0.1s;
            transform-style: preserve-3d;
        }

        /* --- Testimonials Marquee --- */
        .marquee-container {
            overflow: hidden;
            white-space: nowrap;
        }
        
        .marquee-content {
            display: inline-block;
            animation: marquee 30s linear infinite;
        }

        /* --- Footer --- */
        footer {
            background: var(--text-dark);
            color: var(--white);
            position: relative;
            overflow: hidden;
        }

        .footer-link {
            color: #94A3B8;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-link:hover {
            color: var(--light-teal);
            padding-left: 5px;
        }

        /* --- Keyframes --- */
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }

        @keyframes scrollWheel {
            0% { top: 6px; opacity: 1; }
            100% { top: 20px; opacity: 0; }
        }

        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* --- Loading Overlay --- */
        #loader {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: var(--white);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .loader-logo {
            font-family: 'Space Grotesk';
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary-teal);
        }
    </style>
</head>
