    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/studio-freight/lenis@1.0.29/bundled/lenis.min.js"></script>

    <script>
        // Initialize Lenis Smooth Scroll
        const lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            direction: 'vertical',
            gestureDirection: 'vertical',
            smooth: true,
            mouseMultiplier: 1,
            smoothTouch: false,
            touchMultiplier: 2,
        });

        function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Integrate Lenis with GSAP ScrollTrigger
        gsap.registerPlugin(ScrollTrigger);

        // 1. Page Load Animations
        window.addEventListener('load', () => {
            // Hide Loader
            const loaderTl = gsap.timeline();
            loaderTl.to('#loader', { opacity: 0, duration: 0.5, onComplete: () => document.getElementById('loader').style.display = 'none' });

            // Hero Animations
            const heroTl = gsap.timeline({ delay: 0.5 });
            
            heroTl.from('.hero-content h4', { y: 20, opacity: 0, duration: 0.8 })
                  .from('.split-text', { y: 50, opacity: 0, duration: 1, ease: "power3.out" }, "-=0.4")
                  .from('.reveal-text', { y: 30, opacity: 0, duration: 0.8, stagger: 0.2 }, "-=0.6")
                  .from('.hero-buttons', { y: 30, opacity: 0, duration: 0.8 }, "-=0.4")
                  .from('.scale-image', { scale: 0.8, opacity: 0, duration: 1.2, ease: "back.out(1.2)" }, "-=1")
                  .from('.float-element', { y: 50, opacity: 0, duration: 0.8 }, "-=0.8");
        });

        // 2. Horizontal Scroll Section (Services)
        // Note: For horizontal scroll to work well on mobile, we usually allow vertical on mobile and horizontal on desktop.
        // Keeping it simple for this prompt to implement horizontal on all, but constrained.
        
        if (window.innerWidth > 768) {
            let sections = gsap.utils.toArray(".service-panel");
            let scrollTween = gsap.to(sections, {
                xPercent: -100 * (sections.length - 1),
                ease: "none",
                scrollTrigger: {
                    trigger: "#services-wrapper",
                    pin: true,
                    scrub: 1,
                    snap: 1 / (sections.length - 1),
                    end: () => "+=" + document.querySelector("#services-container").offsetWidth
                }
            });
        }

        // 3. About Section Reveals
        gsap.from('.about-img-col', {
            scrollTrigger: {
                trigger: '#about',
                start: 'top 80%',
            },
            x: -50,
            opacity: 0,
            duration: 1
        });

        gsap.from('.about-text-col', {
            scrollTrigger: {
                trigger: '#about',
                start: 'top 80%',
            },
            x: 50,
            opacity: 0,
            duration: 1,
            delay: 0.2
        });

        // Progress Bars Animation
        gsap.utils.toArray('.progress-bar-custom').forEach(bar => {
            gsap.to(bar, {
                width: bar.getAttribute('data-width'),
                duration: 1.5,
                ease: 'power2.out',
                scrollTrigger: {
                    trigger: bar,
                    start: 'top 90%'
                }
            });
        });

        // 4. Platform Showcase (Pinned & Floating)
        gsap.to('.dashboard-mockup', {
            scrollTrigger: {
                trigger: '#platform',
                start: 'top top',
                end: 'bottom top',
                pin: true,
                scrub: true
            },
            scale: 0.9, // Slight zoom effect
            y: 50
        });

        // Animate Feature Cards appearing
        gsap.utils.toArray('.feature-floating-card').forEach((card, i) => {
            gsap.to(card, {
                opacity: 1,
                y: (i + 1) * -20, // Float up slightly
                duration: 1,
                scrollTrigger: {
                    trigger: '#platform',
                    start: 'top 60%',
                    end: 'bottom 20%',
                    toggleActions: 'play none none reverse'
                }
            });
        });

        // 5. Counters Animation
        gsap.utils.toArray('.counter').forEach(counter => {
            let target = counter.getAttribute('data-target');
            gsap.to(counter, {
                innerText: target,
                duration: 2,
                snap: { innerText: 1 },
                scrollTrigger: {
                    trigger: counter,
                    start: 'top 85%'
                }
            });
        });

        // 6. Industries Tilt Effect (Vanilla JS implementation for simplicity + GSAP trigger)
        document.querySelectorAll('.industry-card').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                
                const rotateX = ((y - centerY) / centerY) * -10; // Max 10deg rotation
                const rotateY = ((x - centerX) / centerX) * 10;

                gsap.to(card, {
                    rotationX: rotateX,
                    rotationY: rotateY,
                    transformPerspective: 1000,
                    duration: 0.5,
                    ease: "power2.out"
                });
            });

            card.addEventListener('mouseleave', () => {
                gsap.to(card, {
                    rotationX: 0,
                    rotationY: 0,
                    duration: 0.5,
                    ease: "power2.out"
                });
            });
        });

        // 7. Client Stacking Effect
        gsap.to('.card-stack-item', {
            y: (index) => index * -110, // Stack upwards
            opacity: (index) => 1 - (index * 0.3), // Fade out behind
            scale: 0.95,
            scrollTrigger: {
                trigger: '.client-cards-container',
                start: 'top 70%',
                end: 'top 20%',
                scrub: 1
            }
        });

        // 8. Team Zoom & Socials
        document.querySelectorAll('.team-member').forEach(member => {
            const img = member.querySelector('.zoom-img');
            const socials = member.querySelector('.team-socials');
            
            member.addEventListener('mouseenter', () => {
                gsap.to(img, { scale: 1.1, duration: 0.5 });
                gsap.to(socials, { opacity: 1, duration: 0.3 });
            });
            
            member.addEventListener('mouseleave', () => {
                gsap.to(img, { scale: 1, duration: 0.5 });
                gsap.to(socials, { opacity: 0, duration: 0.3 });
            });
        });

        // 9. Blog Hover Zoom
        document.querySelectorAll('.blog-card').forEach(card => {
            const img = card.querySelector('.blog-img');
            card.addEventListener('mouseenter', () => {
                gsap.to(img, { scale: 1.1, duration: 0.5 });
            });
            card.addEventListener('mouseleave', () => {
                gsap.to(img, { scale: 1, duration: 0.5 });
            });
        });

        // 10. CTA Floating Particles
        gsap.to('.particle', {
            y: 'random(-100, 100)',
            x: 'random(-50, 50)',
            duration: 'random(3, 6)',
            repeat: -1,
            yoyo: true,
            ease: 'sine.inOut'
        });

    </script>
